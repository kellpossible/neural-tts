#!/usr/bin/env python3
"""neural-tts-ctl — control-socket client. Pure stdlib; works under any Python 3.11+."""

from __future__ import annotations

import argparse
import json
import os
import socket
import struct
import sys

DEFAULT_SOCKET = os.environ.get(
    "NEURAL_TTS_CONTROL_SOCKET",
    f"{os.environ.get('XDG_RUNTIME_DIR', f'/run/user/{os.getuid()}')}/neural-tts-control.sock",
)


def _round_trip(sock_path: str, request: dict) -> dict:
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(sock_path)
    except FileNotFoundError:
        print(f"neural-tts-ctl: control socket {sock_path} not present", file=sys.stderr)
        sys.exit(1)
    except ConnectionRefusedError as e:
        print(f"neural-tts-ctl: cannot connect: {e}", file=sys.stderr)
        sys.exit(1)
    try:
        raw = json.dumps(request, separators=(",", ":")).encode("utf-8")
        sock.sendall(struct.pack(">I", len(raw)) + raw)
        sock.shutdown(socket.SHUT_WR)

        head = _recv_exact(sock, 4)
        (length,) = struct.unpack(">I", head)
        body = _recv_exact(sock, length)
        return json.loads(body.decode("utf-8"))
    finally:
        sock.close()


def _recv_exact(sock: socket.socket, n: int) -> bytes:
    buf = bytearray()
    while len(buf) < n:
        chunk = sock.recv(n - len(buf))
        if not chunk:
            raise IOError("short read")
        buf += chunk
    return bytes(buf)


def _cmd_status(args) -> int:
    reply = _round_trip(args.socket, {"op": "status"})
    if not reply.get("ok"):
        print(f"error: {reply.get('error')}", file=sys.stderr)
        return 1
    print(f"provider:       {reply['provider']}")
    print(f"active:         {reply['active'] or '(not running)'}")
    print(f"state:          {reply['state']}")
    print(f"voices:         {reply['voices_count']}")
    print(f"sample rate:    {reply['sample_rate']} Hz")
    print(f"uptime:         {reply['uptime_seconds']:.1f}s")
    print(f"idle:           {reply['idle_for_seconds']:.1f}s / {reply['idle_timeout_seconds']}s")
    return 0


def _cmd_switch(args) -> int:
    reply = _round_trip(args.socket, {"op": "switch", "provider": args.provider})
    if not reply.get("ok"):
        print(f"error: {reply.get('error')}", file=sys.stderr)
        return 1
    print(f"switched to {reply['active']}")
    return 0


def _cmd_reload_voices(args) -> int:
    reply = _round_trip(args.socket, {"op": "reload-voices"})
    if not reply.get("ok"):
        print(f"error: {reply.get('error')}", file=sys.stderr)
        return 1
    print(f"reloaded {reply['voices_count']} voices")
    return 0


def _cmd_list_providers(args) -> int:
    reply = _round_trip(args.socket, {"op": "list-providers"})
    if not reply.get("ok"):
        print(f"error: {reply.get('error')}", file=sys.stderr)
        return 1
    rows = reply["providers"]
    if not rows:
        print("(no providers in registry)")
        return 0
    width = max(len(p["name"]) for p in rows)
    for p in rows:
        marks = []
        if p["active"]:
            marks.append("active")
        if p["installed"]:
            marks.append("installed")
        else:
            marks.append("not installed")
        if p["supports_cloning"]:
            marks.append("cloning")
        print(f"{p['name']:<{width}}  {p['display_name']:<24}  [{', '.join(marks)}]")
        if p.get("notes"):
            print(f"{'':<{width}}      {p['notes']}")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="neural-tts-ctl")
    parser.add_argument("--socket", default=DEFAULT_SOCKET)
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("status", help="Show daemon and active-provider status")

    p_switch = sub.add_parser("switch", help="Switch the active provider")
    p_switch.add_argument("provider")

    sub.add_parser("reload-voices", help="Re-enumerate voices from the active provider")
    sub.add_parser("list-providers", help="List known providers and their install state")

    args = parser.parse_args(argv)

    handlers = {
        "status": _cmd_status,
        "switch": _cmd_switch,
        "reload-voices": _cmd_reload_voices,
        "list-providers": _cmd_list_providers,
    }
    return handlers[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
